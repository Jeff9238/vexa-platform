// 1. CONNECTION
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// 2. USER
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  role      String   @default("USER")
  credits   Int      @default(0)
  createdAt DateTime @default(now())
  listings  Listing[]
}

// 3. LISTING (ADDED CAR PARKS)
model Listing {
  id          String   @id @default(uuid())
  title       String
  description String
  price       Float
  type        String   // "PROPERTY" or "VEHICLE"
  tags        String
  images      String
  location    String   @default("Malaysia")
  
  // Location Split
  area        String   @default("City")
  state       String   @default("Malaysia")
  
  // Status
  condition   String?
  verified    Boolean  @default(false)
  
  // Property Fields
  listingCategory String? 
  facilities      String? 
  bedrooms    Int?
  bathrooms   Int?
  carParks    Int?     // <--- NEW FIELD
  sqft        Int?
  propertyType String? 
  furnishing  String?

  // Vehicle Fields
  brand       String?
  model       String?
  year        Int?
  variant     String?
  series      String?
  color       String?
  mileage     Int?
  transmission String?
  fuelType    String?
  bodyType    String?
  seats       Int?
  origin      String?
  engineCC    Int?
  peakPower   Int?
  peakTorque  Int?

  published   Boolean  @default(false)
  createdAt   DateTime @default(now())

  userId      String
  user        User     @relation(fields: [userId], references: [id])
}