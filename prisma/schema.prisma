// 1. CONNECTION CONFIGURATION
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// 2. ENUMS
enum UserRole {
  USER
  ADMIN
}

enum ListingStatus {
  ACTIVE
  SOLD
  HIDDEN
}

enum ListingType {
  PROPERTY
  VEHICLE
}

// 3. USER MODEL
model User {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String?
  role         UserRole @default(USER)
  credits      Int      @default(0)
  verified     Boolean  @default(false)
  
  // Profile
  phoneNumber  String?
  bio          String?
  website      String?
  profileImage String?
  createdAt    DateTime @default(now())
  
  listings     Listing[]
  favorites    Favorite[]
  
  // Chat Relations
  chatsAsBuyer  ChatRoom[] @relation("BuyerChats")
  chatsAsSeller ChatRoom[] @relation("SellerChats")
  messages      Message[]

  // Trust & Safety Relations
  reportsMade   Report[]   @relation("UserReports")
  reviewsGiven  Review[]   @relation("Reviewer")
  reviewsReceived Review[] @relation("Reviewee")

  // User Retention (FIXED: Added this relation)
  savedSearches SavedSearch[]
}

// 4. FAVORITE MODEL
model Favorite {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  listingId String

  @@unique([userId, listingId])
  @@index([userId])
}

// 5. LISTING MODEL
model Listing {
  id           String   @id @default(uuid())
  title        String
  description  String
  price        Float
  negotiable   Boolean  @default(false)
  type         String   
  tags         String
  images       String
  
  // Location
  location     String   @default("Malaysia")
  area         String   @default("City")
  state        String   @default("Malaysia")
  locationName String?
  lat          Float?
  lng          Float?
  
  status       ListingStatus @default(ACTIVE) 
  condition    String?
  verified     Boolean  @default(false)
  published    Boolean  @default(true)
  createdAt    DateTime @default(now())

  // Analytics
  views           Int      @default(0)
  whatsappClicks  Int      @default(0)
  callClicks      Int      @default(0)
  
  // --- PROPERTY SPECIFIC ---
  listingCategory String?
  propertyType  String?
  tenure        String?
  propertyTitle String?
  landTitle     String?
  
  bedrooms      Int?
  bathrooms     Int?
  carParks      Int?
  
  sqft          Int?
  landArea      Int?
  
  furnishing    String?
  unitType      String?
  occupancy     String?
  maintenanceFee Float?
  
  facilities    String?

  // --- VEHICLE SPECIFIC ---
  brand         String?
  model         String?
  variant       String?
  series        String?
  
  year          Int?
  regYear       Int?
  
  bodyType      String?
  color         String?
  mileage       String?
  transmission  String?
  fuelType      String?
  engineCC      Int?
  
  assembly      String?
  seats         Int?
  
  peakPower     Int?
  peakTorque    Int?
  
  warranty      Boolean?
  serviceHistory Boolean?
  prevOwners    Int?
  wheelSize     Int?
  plateNumber   String?

  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  favorites     Favorite[]
  
  chats         ChatRoom[]
  reports       Report[]

  @@index([type, status, published]) 
  @@index([price])
  @@index([state])
  @@index([brand])
  @@index([createdAt])
}

// 6. NEWS ARTICLE
model NewsArticle {
  id        String   @id @default(uuid())
  title     String
  summary   String
  content   String 
  category  String   
  imageUrl  String
  createdAt DateTime @default(now())

  @@index([createdAt])
}

// 7. CHAT SYSTEM
model ChatRoom {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  listingId String
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  buyerId   String
  buyer     User    @relation("BuyerChats", fields: [buyerId], references: [id], onDelete: Cascade)

  sellerId  String
  seller    User    @relation("SellerChats", fields: [sellerId], references: [id], onDelete: Cascade)

  messages  Message[]

  @@unique([listingId, buyerId, sellerId])
  @@index([buyerId])
  @@index([sellerId])
}

model Message {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  text      String
  isRead    Boolean  @default(false)

  chatRoomId String
  chatRoom   ChatRoom @relation(fields: [chatRoomId], references: [id], onDelete: Cascade)

  senderId   String
  sender     User     @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([chatRoomId])
}

// 8. TRUST & SAFETY
model Report {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  reason    String   
  details   String?  
  status    String   @default("PENDING") 

  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  reporterId String
  reporter   User    @relation("UserReports", fields: [reporterId], references: [id], onDelete: Cascade)
}

model Review {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  rating    Int      
  comment   String?

  agentId   String   
  agent     User     @relation("Reviewee", fields: [agentId], references: [id], onDelete: Cascade)

  reviewerId String  
  reviewer   User    @relation("Reviewer", fields: [reviewerId], references: [id], onDelete: Cascade)

  @@index([agentId])
}

// 9. SAVED SEARCHES (USER RETENTION)
model SavedSearch {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  
  // Search Criteria
  type            String?  
  query           String?  
  minPrice        Float?
  maxPrice        Float?
  state           String?
  
  // Specifics
  brand           String?
  model           String?
  propertyType    String?
  listingCategory String? 

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}