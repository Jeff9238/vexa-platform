model Listing {
  id           String   @id @default(uuid())
  title        String
  description  String
  price        Float
  type         String   
  tags         String
  images       String
  location     String   @default("Malaysia")
  
  // Location Split
  area         String   @default("City")
  state        String   @default("Malaysia")
  locationName String?
  lat          Float?
  lng          Float?
  status       ListingStatus @default(ACTIVE) 
  
  condition    String?
  verified     Boolean  @default(false)
  published    Boolean  @default(true)
  createdAt    DateTime @default(now())

  // Analytics
  views           Int      @default(0)
  whatsappClicks  Int      @default(0)
  callClicks      Int      @default(0)
  
  // --- PROPERTY FIELDS (Updated) ---
  bedrooms      Int?
  bathrooms     Int?
  sqft          Int?
  carParks      Int?
  propertyType  String?
  furnishing    String?
  listingCategory String?
  facilities    String?
  
  // NEW PROPERTY FIELDS
  tenure        String?  // Freehold / Leasehold
  propertyTitle String?  // Individual / Strata
  landArea      Int?     // For Landed
  unitType      String?  // Intermediate / Corner
  maintenanceFee Float?  // For Stratified properties
  occupancy     String?  // Vacant / Tenanted

  // --- VEHICLE FIELDS (Updated) ---
  brand         String?
  model         String?
  year          Int?
  variant       String?
  series        String?
  color         String?
  mileage       Int?
  transmission  String?
  fuelType      String?
  bodyType      String?
  seats         Int?
  origin        String?
  engineCC      Int?
  peakPower     Int?
  peakTorque    Int?

  // NEW VEHICLE FIELDS
  warranty      Boolean? // True if Under Warranty
  serviceHistory Boolean? // True if Full Service History
  wheelSize     Int?     // e.g. 19 inch
  plateNumber   String?  // e.g. "P" or "W"

  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  favorites     Favorite[]

  @@index([type, status, published]) 
  @@index([price])
  @@index([state])
  @@index([brand])
  @@index([createdAt])
}