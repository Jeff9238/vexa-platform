// 1. CONNECTION
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// 2. USER
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  role      String   @default("USER")
  credits   Int      @default(0)
  createdAt DateTime @default(now())
  listings  Listing[]
  favorites Favorite[] // <--- RESTORED
}

// 3. FAVORITE (RESTORED)
model Favorite {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  listingId String

  @@unique([userId, listingId])
}

// 4. LISTING
model Listing {
  id          String   @id @default(uuid())
  title       String
  description String
  price       Float
  type        String   // "PROPERTY" or "VEHICLE"
  tags        String
  images      String
  location    String   @default("Malaysia")
  
  // Location Split
  area        String   @default("City")
  state       String   @default("Malaysia")
  locationName String?
  lat         Float?
  lng         Float?
  
  // Status
  condition   String?
  verified    Boolean  @default(false)

  // Property
  bedrooms    Int?
  bathrooms   Int?
  sqft        Int?
  carParks    Int?
  propertyType String?
  furnishing  String?
  listingCategory String?
  facilities      String?

  // Vehicle
  brand       String?
  model       String?
  year        Int?
  variant     String?
  series      String?
  color       String?
  mileage     Int?
  transmission String?
  fuelType    String?
  bodyType    String?
  seats       Int?
  origin      String?
  engineCC    Int?
  peakPower   Int?
  peakTorque  Int?
  // Removed L/W/H as requested

  published   Boolean  @default(false)
  createdAt   DateTime @default(now())

  userId      String
  user        User     @relation(fields: [userId], references: [id])
  favorites   Favorite[] // <--- RESTORED
}