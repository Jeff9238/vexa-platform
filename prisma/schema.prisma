// 1. CONNECTION
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// 2. USER
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  role      String   @default("USER")
  credits   Int      @default(0)
  createdAt DateTime @default(now())
  listings  Listing[]
}

// 3. LISTING (UPDATED FOR PROPERTY)
model Listing {
  id          String   @id @default(uuid())
  title       String
  description String
  price       Float
  type        String   // "PROPERTY" or "VEHICLE"
  tags        String
  images      String
  location    String   @default("Malaysia")
  
  // --- NEW LOCATION SPLIT ---
  area        String   @default("City")
  state       String   @default("Malaysia")

  // --- SHARED STATUS ---
  condition   String?  // New, Used, Recon (Vehicles)
  verified    Boolean  @default(false)
  
  // --- NEW PROPERTY FIELDS ---
  listingCategory String? // "SALE" or "RENT"
  facilities      String? // "Pool,Gym,Security" (Comma separated)

  // --- PROPERTY SPECS ---
  bedrooms    Int?
  bathrooms   Int?
  sqft        Int?
  propertyType String? // Added Factory, Land, etc.
  furnishing  String?

  // --- VEHICLE SPECS (UNCHANGED) ---
  brand       String?
  model       String?
  year        Int?
  variant     String?
  series      String?
  color       String?
  mileage     Int?
  transmission String?
  fuelType    String?
  bodyType    String?
  seats       Int?
  origin      String?
  engineCC    Int?
  peakPower   Int?
  peakTorque  Int?
  length      Int?
  width       Int?
  height      Int?
  wheelBase   Int?
  kerbWeight  Int?
  fuelTank    Int?

  published   Boolean  @default(false)
  createdAt   DateTime @default(now())

  userId      String
  user        User     @relation(fields: [userId], references: [id])
}